{
    "database": {
        "filename": "soulsense.db",
        "path": "db"
    },
    "ui": {
        "theme": "light",
        "window_size": "800x600"
    },
    "features": {
        "enable_journal": true,
        "enable_analytics": true
    },
    "exam": {
        "num_questions": 5
    },
    "latency_budgets": {
        "enabled": true,
        "alert_on_breach": true,
        "budgets": {
            "exam_service.get_results": {
                "budget_ms": 500,
                "operation_type": "query",
                "alert_threshold_percent": 80
            },
            "exam_service.check_retake_allowed": {
                "budget_ms": 400,
                "operation_type": "query",
                "alert_threshold_percent": 80
            },
            "journal_service.create_entry": {
                "budget_ms": 1000,
                "operation_type": "command",
                "alert_threshold_percent": 75
            },
            "journal_service.get_entries": {
                "budget_ms": 600,
                "operation_type": "query",
                "alert_threshold_percent": 80
            },
            "profile_service.get_profile": {
                "budget_ms": 500,
                "operation_type": "query",
                "alert_threshold_percent": 80
            }
        }
    },
    "cost_monitoring": {
        "enabled": true,
        "alert_on_anomaly": true,
        "baseline_days": 7,
        "services": {
            "api_compute": {
                "daily_budget_usd": 50.0,
                "spike_threshold_percent": 20,
                "rate_of_change_multiplier": 2.0
            },
            "ml_endpoints": {
                "daily_budget_usd": 100.0,
                "spike_threshold_percent": 25,
                "rate_of_change_multiplier": 2.0
            },
            "database": {
                "daily_budget_usd": 30.0,
                "spike_threshold_percent": 15,
                "rate_of_change_multiplier": 1.5
            }
        }
    },
    "experimental": {
        "ai_journal_suggestions": false,
        "advanced_analytics": false,
        "beta_ui_components": false,
        "ml_emotion_detection": false,
        "data_export_v2": false
    }
}